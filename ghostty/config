theme = Catppuccin Mocha
font-size = 19
background-blur-radius = 20
mouse-hide-while-typing = true
window-decoration = true
macos-option-as-alt = true

# Native macOS tabs. Cmd+T creates a grouped window that AeroSpace sees as a
# new tile; workspace splits between the two Ghostty windows. Use the
# re-tile flow in the README when this happens (close or merge back).
macos-titlebar-style = native
window-new-tab-position = end

# Every new Ghostty window opens in the twin-andie repo by default.
# Override per-session by launching from another cwd.
working-directory = /Users/casadolimiar/Flowen/twin-andie
