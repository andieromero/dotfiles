# A simple sketchybar config for aerospace users to get started with
# Not too different from the base starting config!

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items" 

#### Import Colors
source "$CONFIG_DIR/colors.sh" # Loads all defined colors

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top height=40 corner_radius=30 color=$BAR_COLOR \
                 y_offset=30 \
                 margin=8 \
                 topmost=window \
                 sticky=on \
                 display=all \
                 padding_left=10 padding_right=10
# y_offset=30 clears the MacBook camera/notch area when running on the built-in
# display only. Costs ~25px on external displays but that's the tradeoff for
# notch-safety. Aerospace gaps below need to match (see aerospace.toml outer.top).

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=2
  padding_right=2
  icon.font="Hack Nerd Font:Bold:14.0"
  label.font="SF Pro:Semibold:14.0"
  #icon.color=0xffffffff
  icon.color=$WHITE
  #label.color=0xffffffff
  label.color=$WHITE
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
  updates=on
)
sketchybar --default "${default[@]}"

##### Adding aeropsace layouts #####

# Add the aerospace_workspace_change event we specified in aerospace.toml.
# aerospace_mode_changed fires when you enter/exit service mode — used for the
# layout-mode indicator pill on the left.
sketchybar --add event aerospace_workspace_change
sketchybar --add event aerospace_mode_changed

# Refresh button moved to the far right of the bar — see end of the right chain below.

# Add workspaces 1-8 only (workspace 9 is secondary scratch, not shown in bar).
# Pills render on every attached display so the bar is consistent no matter
# which monitor you're looking at.
#
# Icons come from Hack Nerd Font (already set as default icon.font). The
# mapping reflects the workspace layout:
#   1 browser   2 code     3 terminal  4 email
#   5 free      6 chat     7 music     8 meetings
for sid in $(aerospace list-workspaces --all); do
    if ! [[ "$sid" =~ ^[0-9]+$ ]]; then continue; fi
    if [ "$sid" -gt 8 ]; then continue; fi

    # Icons match the new layout:
    #   1 scratch/secondary   2 chat (Slack)       3 free       4 free
    #   5 terminal            6 code               7 browser    8 overflow/inbox
    case "$sid" in
      1) ws_icon=""; ws_color=0xfffdd835 ;;   # star — scratch (yellow)
      2) ws_icon=""; ws_color=0xff4fc3f7 ;;   # speech bubble — chat (sky blue)
      3) ws_icon=""; ws_color=0xff81c784 ;;   # plus — free (green)
      4) ws_icon=""; ws_color=0xff81c784 ;;   # plus — free (green)
      5) ws_icon=""; ws_color=0xffba68c8 ;;   # terminal (violet)
      6) ws_icon=""; ws_color=0xffff8a65 ;;   # code (coral)
      7) ws_icon=""; ws_color=0xff4db6ac ;;   # globe — browser (teal)
      8) ws_icon=""; ws_color=0xffffb74d ;;   # inbox — overflow (amber)
      *) ws_icon=""; ws_color=0xffffffff ;;
    esac
    # Pill shows "<number> <glyph>" so you always know the shortcut.
    # Number stays white, glyph gets the per-workspace color via a color-glyph prefix.
    pill_icon="$sid $ws_icon"

    # Single-item workspace pill — number + glyph + app icons in one label.
    # Icon = "<n> <themed-glyph>" (e.g. "5 ").
    # Label = sketchybar-app-font glyphs for apps in that workspace.
    # Bg colored hot pink only when this is the keyboard-focused workspace.
    pill_icon="$sid $ws_icon"
    sketchybar --add item space.$sid left \
      --subscribe space.$sid aerospace_workspace_change \
      --set space.$sid \
      update_freq=2 \
      drawing=on \
      padding_left=2 \
      padding_right=2 \
      background.color=$ITEM_BG_COLOR \
      background.corner_radius=5 \
      background.drawing=on \
      background.border_color=$HOT_PURPLE \
      background.border_width=0 \
      background.height=22 \
      icon="$pill_icon" \
      icon.color=$WHITE \
      icon.padding_left=8 \
      icon.padding_right=4 \
      label.font="sketchybar-app-font:Regular:12.0" \
      label.padding_left=0 \
      label.padding_right=8 \
      label.y_offset=-1 \
      label.color=$WHITE \
      click_script="aerospace workspace $sid" \
      script="$CONFIG_DIR/plugins/aerospace.sh $sid"
done

# Initial populate
for sid in 1 2 3 4 5 6 7 8; do
  "$CONFIG_DIR/plugins/aerospace.sh" "$sid" >/dev/null 2>&1 &
done
wait


# Chevron separator between workspace pills and the front-app block
sketchybar --add item chevron left \
  --set chevron icon= label.drawing=off icon.padding_left=10 icon.padding_right=10

# Front app (focused app name) + layout-mode indicator (tiles/accordion/floating)
source "$ITEM_DIR/front_app.sh"

sketchybar --add item front_app_layout right \
  --set front_app_layout \
    update_freq=2 \
    padding_left=0 \
    icon.drawing=on \
    icon.font="Hack Nerd Font:Regular:14.0" \
    icon.color=$FRONT_APP_LAYOUT_ICON_COLOR \
    icon.padding_left=2 \
    icon.padding_right=4 \
    label.drawing=on \
    label.font="SF Pro:Semibold:9.0" \
    label.color=$WHITE \
    label.padding_left=0 \
    label.padding_right=4 \
    background.drawing=on \
    background.color=$FRONT_APP_LAYOUT_BG_COLOR \
    background.corner_radius=4 \
    background.height=18 \
    script="$PLUGIN_DIR/front_app.sh" \
    click_script="$PLUGIN_DIR/layout_toggle.sh" \
  --subscribe front_app_layout front_app_switched aerospace_mode_changed aerospace_workspace_change


##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other gititems respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events

sketchybar --add item refresh right \
  --set refresh \
    icon="󰜉" \
    icon.color=$WHITE \
    icon.font="Hack Nerd Font:Bold:14.0" \
